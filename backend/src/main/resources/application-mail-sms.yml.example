# 邮件和短信服务配置示例
# 将此文件重命名为 application-mail-sms.yml 并填入真实配置

spring:
  # 邮件配置
  mail:
    enabled: true  # 是否启用邮件服务
    host: smtp.qq.com  # SMTP服务器地址（QQ邮箱示例）
    port: 587  # SMTP端口
    username: your-email@qq.com  # 发件人邮箱
    password: your-authorization-code  # 邮箱授权码（不是登录密码）
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
            required: true
    default-encoding: UTF-8

# 阿里云短信配置
aliyun:
  sms:
    enabled: true  # 是否启用短信服务
    access-key-id: your-access-key-id  # 阿里云AccessKey ID
    access-key-secret: your-access-key-secret  # 阿里云AccessKey Secret
    sign-name: 文物管理系统  # 短信签名
    template-code: SMS_123456789  # 短信模板CODE

# 配置说明：
# 
# 1. QQ邮箱配置：
#    - host: smtp.qq.com
#    - port: 587 或 465（SSL）
#    - username: 你的QQ邮箱
#    - password: QQ邮箱授权码（在QQ邮箱设置-账户-POP3/IMAP/SMTP服务中获取）
#
# 2. 163邮箱配置：
#    - host: smtp.163.com
#    - port: 465
#    - username: 你的163邮箱
#    - password: 163邮箱授权码
#
# 3. Gmail配置：
#    - host: smtp.gmail.com
#    - port: 587
#    - username: 你的Gmail邮箱
#    - password: Gmail应用专用密码
#
# 4. 阿里云短信配置：
#    - 登录阿里云控制台：https://dysms.console.aliyun.com/
#    - 创建AccessKey：https://ram.console.aliyun.com/manage/ak
#    - 申请短信签名和模板
#    - 短信模板示例：您的验证码是${code}，有效期${expire}分钟
