<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.SysRoleMapper">

    <select id="selectById" resultType="com.example.entity.SysRole">
        SELECT * FROM sys_role WHERE id = #{id} LIMIT 1
    </select>

    <select id="selectEnabledList" resultType="com.example.entity.SysRole">
        SELECT * FROM sys_role WHERE status = 1 ORDER BY id ASC
    </select>

</mapper>
