<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.UserMuseumMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.UserMuseum">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="museumId" column="museum_id"/>
        <result property="isPrimary" column="is_primary"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap id="WithMuseumNameResultMap" type="com.example.entity.UserMuseum" extends="BaseResultMap">
        <result property="museumName" column="museumName"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM user_museum WHERE user_id = #{userId}
    </select>

    <select id="selectPrimaryByUserId" resultMap="BaseResultMap">
        SELECT * FROM user_museum WHERE user_id = #{userId} AND is_primary = 1 LIMIT 1
    </select>

    <select id="selectPrimaryWithMuseumNameByUserId" resultMap="WithMuseumNameResultMap">
        SELECT um.*, m.museum_name as museumName
        FROM user_museum um
        LEFT JOIN museum m ON um.museum_id = m.id
        WHERE um.user_id = #{userId} AND um.is_primary = 1
        LIMIT 1
    </select>

    <select id="selectByMuseumId" resultMap="BaseResultMap">
        SELECT * FROM user_museum WHERE museum_id = #{museumId}
    </select>

    <insert id="insert" parameterType="com.example.entity.UserMuseum"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_museum (user_id, museum_id, is_primary)
        VALUES (#{userId}, #{museumId}, #{isPrimary})
    </insert>

    <update id="update" parameterType="com.example.entity.UserMuseum">
        UPDATE user_museum SET museum_id = #{museumId}, is_primary = #{isPrimary}
        WHERE id = #{id}
    </update>

    <delete id="deleteByUserId">
        DELETE FROM user_museum WHERE user_id = #{userId}
    </delete>

    <delete id="deleteById">
        DELETE FROM user_museum WHERE id = #{id}
    </delete>

    <select id="countByUserIdAndMuseumId" resultType="int">
        SELECT COUNT(*) FROM user_museum WHERE user_id = #{userId} AND museum_id = #{museumId}
    </select>

</mapper>
