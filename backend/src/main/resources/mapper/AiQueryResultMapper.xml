<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.AiQueryResultMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.AiQueryResult">
        <id property="id" column="id"/>
        <result property="messageId" column="message_id"/>
        <result property="relicId" column="relic_id"/>
        <result property="relicName" column="relic_name"/>
        <result property="relevancePercent" column="relevance_percent"/>
        <result property="isExternal" column="is_external"/>
        <result property="sourceName" column="source_name"/>
        <result property="sourceType" column="source_type"/>
        <result property="sourceUrl" column="source_url"/>
        <result property="matchTags" column="match_tags"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.entity.AiQueryResult"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_query_result (message_id, relic_id, relic_name, relevance_percent, is_external, source_name, source_type, source_url, match_tags)
        VALUES (#{messageId}, #{relicId}, #{relicName}, #{relevancePercent}, #{isExternal}, #{sourceName}, #{sourceType}, #{sourceUrl}, #{matchTags})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM ai_query_result WHERE id = #{id}
    </select>

    <select id="selectByMessageId" resultMap="BaseResultMap">
        SELECT * FROM ai_query_result WHERE message_id = #{messageId} ORDER BY relevance_percent DESC
    </select>

    <delete id="deleteByMessageId">
        DELETE FROM ai_query_result WHERE message_id = #{messageId}
    </delete>

    <select id="selectBySessionId" resultMap="BaseResultMap">
        SELECT * FROM ai_query_result WHERE message_id IN
        (SELECT id FROM ai_chat_message WHERE session_id = #{sessionId})
    </select>

</mapper>
