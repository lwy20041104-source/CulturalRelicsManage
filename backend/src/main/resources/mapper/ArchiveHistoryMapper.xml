<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ArchiveHistoryMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.ArchiveHistory">
        <id property="id" column="id"/>
        <result property="archiveId" column="archive_id"/>
        <result property="version" column="version"/>
        <result property="operationType" column="operation_type"/>
        <result property="operationContent" column="operation_content"/>
        <result property="changeLog" column="change_log"/>
        <result property="operatorId" column="operator_id"/>
        <result property="operatorName" column="operator_name"/>
        <result property="operationTime" column="operation_time"/>
        <result property="ipAddress" column="ip_address"/>
    </resultMap>

    <select id="selectByArchiveId" resultMap="BaseResultMap">
        SELECT * FROM archive_history
        WHERE archive_id = #{archiveId}
        ORDER BY operation_time DESC
    </select>

    <select id="selectByArchiveIdAndVersion" resultMap="BaseResultMap">
        SELECT * FROM archive_history
        WHERE archive_id = #{archiveId} AND version = #{version}
        ORDER BY operation_time DESC
    </select>

    <insert id="insert" parameterType="com.example.entity.ArchiveHistory"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO archive_history (archive_id, version, operation_type, operation_content,
        change_log, operator_id, operator_name, operation_time, ip_address)
        VALUES (#{archiveId}, #{version}, #{operationType}, #{operationContent},
        #{changeLog}, #{operatorId}, #{operatorName}, #{operationTime}, #{ipAddress})
    </insert>

    <delete id="deleteByArchiveId">
        DELETE FROM archive_history WHERE archive_id = #{archiveId}
    </delete>

</mapper>
