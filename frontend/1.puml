}

' ========== 六、通知管理实体 ==========
package "六、通知管理实体" {
  
  class SystemNotification {
    - id: Long
    - title: String
    - content: String
    - type: String
    - priority: String
    - relatedType: String
    - relatedId: Long
    - senderId: Long
    - senderName: String
    - createTime: LocalDateTime
  }
  
  class UserNotification {
    - id: Long
    - notificationId: Long
    - userId: Long
    - isRead: Integer
    - readTime: LocalDateTime
    - createTime: LocalDateTime
  }
  
  class NotificationConfig {
    - id: Long
    - userId: Long
    - notificationType: String
    - enabled: Integer
    - emailEnabled: Integer
    - smsEnabled: Integer
    - createTime: LocalDateTime
    - updateTime: LocalDateTime
  }
}

' ========== 七、AI智能查询实体 ==========
package "七、AI智能查询实体" {
  
  class AiChatSession {
    - id: Long
    - userId: Long
    - sessionTitle: String
    - createTime: LocalDateTime
    - updateTime: LocalDateTime
  }
  
  class AiChatMessage {
    - id: Long
    - sessionId: Long
    - userId: Long
