    - updateTime: LocalDateTime
  }
  
  class SysRestore {
    - id: Long
    - backupId: Long
    - restoreTime: LocalDateTime
    - status: String
    - operator: String
    - remark: String
  }
  
  class VerificationCode {
    - id: Long
    - userId: Long
    - username: String
    - code: String
    - type: String
    - contact: String
    - purpose: String
    - used: Integer
    - expireTime: LocalDateTime
    - createTime: LocalDateTime
  }
  
  class Warehouse {
    - id: Long
    - warehouseName: String
    - warehouseCode: String
    - location: String
    - capacity: Integer
    - currentCount: Integer
    - managerId: Long
    - status: Integer
    - createTime: LocalDateTime
    - updateTime: LocalDateTime
  }
  
  class DataChangeDetail {
    - id: Long
    - tableName: String
    - recordId: Long
    - changeType: String
    - fieldName: String
    - oldValue: String
    - newValue: String
    - operatorId: Long
    - operatorName: String
