    - hasExternalResult: Integer
    - relicIds: String
    - createTime: LocalDateTime
  }
  
  class AiQueryResult {
    - id: Long
    - messageId: Long
    - relicId: Long
    - relevance: Integer
    - sourceType: String
    - sourceName: String
    - matchTags: String
    - createTime: LocalDateTime
  }
}

' ========== 八、系统管理实体 ==========
package "八、系统管理实体" {
  
  class SysOperationLog {
    - id: Long
    - userId: Long
    - operator: String
    - operationType: String
    - operationModule: String
    - operationContent: String
    - operationResult: String
    - ipAddress: String
    - resourceType: String
    - resourceId: Long
    - beforeData: String
    - afterData: String
    - changedFields: String
    - requestMethod: String
    - requestUrl: String
    - requestParams: String
    - responseData: String
    - errorMessage: String
    - executionTime: Long
    - userAgent: String
