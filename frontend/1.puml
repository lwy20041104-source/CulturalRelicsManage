    - createTime: LocalDateTime
    - remark: String
  }
  
  class SysBackupConfig {
    - id: Long
    - backupPath: String
    - autoBackup: Integer
    - backupInterval: Integer
    - retentionDays: Integer
    - maxBackupCount: Integer
