  }
}

' ========== 九、工具类 ==========
package "九、工具类" {
  
  class JwtUtil {
    - SECRET_KEY: String
    - EXPIRATION_TIME: long
    --
    + generateToken(String): String
    + validateToken(String): boolean
    + getUsernameFromToken(String): String
    + isTokenExpired(String): boolean
  }
  
  class FileStorageUtil {
    - uploadPath: String
    - allowedExtensions: List
    --
    + uploadFile(MultipartFile): String
    + deleteFile(String): boolean
    + getFileUrl(String): String
    + validateFile(MultipartFile): boolean
  }
  
  class QRCodeUtil {
    --
    + generateQRCode(String, int): BufferedImage
    + generateQRCodeBase64(String, int): String
    + generateRelicQRCodeUrl(Long, String): String
    + generateQRCodeLabelBase64(...): String
  }
  
  class UserContextUtil {
    --
    + getCurrentUserId(): Long
    + getCurrentUsername(): String
    + getCurrentUserRealName(): String
    + getCurrentUserRole(): String
    + hasRole(String): boolean
    + hasPermission(String): boolean
  }
}

' ========== 实体关系 ==========
' 文物管理关系
CulturalRelic "N" -- "1" CulturalRelicCategory
CulturalRelic "1" -- "0..*" RelicImageRelation
RelicImageRelation "N" -- "1" ImageLibrary

' 修复管理关系
CulturalRelic "1" -- "0..*" RepairRecord
RepairRecord "1" -- "0..*" RepairRecordMaterial
RepairMaterial "1" -- "0..*" RepairRecordMaterial

' 维护管理关系
CulturalRelic "1" -- "0..*" MaintenanceRecord

' 用户权限关系
SysUser "N" -- "1" SysRole
SysUser "1" -- "0..*" UserMuseum
UserMuseum "N" -- "1" Museum

' 档案管理关系
CulturalRelic "1" -- "0..*" RelicArchive
RelicArchive "1" -- "0..*" ArchiveDocument
RelicArchive "1" -- "0..*" ArchiveHistory
RelicArchive "1" -- "0..*" ArchiveRelation
RelicArchive "1" -- "0..*" ArchiveVersion

' 通知管理关系
SystemNotification "1" -- "0..*" UserNotification
SysUser "1" -- "0..*" UserNotification
SysUser "1" -- "0..*" NotificationConfig

' AI查询关系
SysUser "1" -- "0..*" AiChatSession
AiChatSession "1" -- "0..*" AiChatMessage
AiChatMessage "1" -- "0..*" AiQueryResult
AiQueryResult "N" -- "1" CulturalRelic

' 系统管理关系
SysUser "1" -- "0..*" SysOperationLog

' ========== 图例说明 ==========
legend bottom right
  | 符号 | 含义 |
  | ---- | ---- |
  | 1 -- 0..* | 一对多关联 |
  | N -- 1 | 多对一关联 |
  | N -- M | 多对多关联 |
  | 实体类 | 业务实体 |
  | 工具类 | 辅助工具 |
endlegend

@enduml