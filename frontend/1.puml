@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageStyle rectangle
skinparam shadowing false

' ========== 中文字体设置 ==========
!pragma useunicode true
skinparam defaultFontName "Microsoft YaHei" "SimHei" "SimSun"

title 基于SpringBoot的博物馆文物数字化管理平台 - 实体类图

' ========== 核心业务实体 ==========
package "核心业务" {
  
  class CulturalRelic {
    + id: Long
    + relicCode: String
    + relicName: String
    + categoryId: Long
    + era: String
    + material: String
    + status: String
    + imagePath: String
    + model3dUrl: String
    --
    + getById()
    + save()
    + update()
    + delete()
  }
  
  class CulturalRelicCategory {
    + id: Long
    + categoryName: String
    + parentId: Long
    + description: String
    --
    + getChildren()
  }
  
  class ImageLibrary {
    + id: Long
    + imageName: String
    + filePath: String
    + fileSize: Long
    + tags: String
    --
    + upload()
    + delete()
  }
}

' ========== 修复管理 ==========
package "修复管理" {
  
  class RepairRecord {
    + id: Long
    + repairCode: String
    + relicId: Long
    + status: String
    + priority: String
    + applicantId: Long
    + estimatedCost: BigDecimal
    + actualCost: BigDecimal
    + repairExpert: String
    + qualityScore: Integer
    --
    + apply()
    + approve()
    + start()
    + complete()
  }
  
  class RepairMaterial {
    + id: Long
    + materialName: String
    + materialCode: String
    + unitPrice: BigDecimal
    + stockQuantity: BigDecimal
  }
}

' ========== 档案管理 ==========
package "档案管理" {
  
  class RelicArchive {
    + id: Long
    + relicId: Long
    + archiveCode: String
    + archiveTitle: String
    + version: Integer
    + status: String
    --
    + create()
    + update()
    + publish()
  }
  
  class ArchiveDocument {
    + id: Long
    + archiveId: Long
    + documentName: String
    + filePath: String
    + fileFormat: String
  }
}

' ========== 用户权限 ==========
package "用户权限" {
  
  class SysUser {
    + id: Long
    + username: String
    + realName: String
    + email: String
    + phone: String
    + roleId: Long
    + status: Integer
    --
    + login()
    + logout()
    + changePassword()
  }
  
  class SysRole {
    + id: Long
    + roleName: String
    + roleCode: String
    + description: String
  }
}

' ========== AI智能查询 ==========
package "AI智能查询" {
  
  class AiChatSession {
    + id: Long
    + userId: Long
    + sessionTitle: String
    + createTime: LocalDateTime
  }
  
  class AiChatMessage {
    + id: Long
    + sessionId: Long
    + content: String
    + messageType: String
  }
}

' ========== 系统管理 ==========
package "系统管理" {
  
  class SysOperationLog {
    + id: Long
    + userId: Long
    + operationType: String
    + operationModule: String
    + ipAddress: String
    + operationTime: LocalDateTime
  }
  
  class SysBackup {
    + id: Long
    + backupName: String
    + backupPath: String
    + backupSize: Long
    + status: String
  }
}

' ========== 工具类 ==========
package "工具类" #E8F4FD {
  
  class JwtUtil {
    + generateToken(): String
    + validateToken(): boolean
    + getUsernameFromToken(): String
  }
  
  class FileStorageUtil {
    + uploadFile(): String
    + deleteFile(): boolean
    + getFileUrl(): String
  }
  
  class QRCodeUtil {
    + generateQRCode(): BufferedImage
    + generateQRCodeBase64(): String
  }
  
  class UserContextUtil {
    + getCurrentUserId(): Long
    + getCurrentUsername(): String
    + hasRole(): boolean
  }
}

' ========== 1. 继承关系 (Inheritance) ==========
' 实线 + 空心三角形箭头
CulturalRelic <|-- CulturalRelicCategory
RepairMaterial <|-- RepairRecord


' ========== 2. 实现关系 (Realization) ==========
' 虚线 + 空心三角形箭头


' ========== 3. 聚合关系 (Aggregation) ==========
' 实线 + 空心菱形箭头
SysUser o-- SysRole


' ========== 4. 组合关系 (Composition) ==========
' 实线 + 实心菱形箭头
RelicArchive *-- ArchiveDocument
AiChatSession *-- AiChatMessage


' ========== 5. 关联关系 (Association) ==========
' 实线箭头
CulturalRelic "1" --> "*" CulturalRelicCategory
CulturalRelic "1" --> "*" ImageLibrary
CulturalRelic "1" --> "*" RepairRecord
CulturalRelic "1" --> "1" RelicArchive
RelicArchive "1" --> "*" ArchiveDocument
SysUser "1" --> "*" RepairRecord
SysUser "1" --> "*" SysOperationLog
SysUser "1" --> "*" AiChatSession
SysUser "*" --> "1" SysRole
AiChatSession "1" --> "*" AiChatMessage
RepairRecord "*" --> "*" RepairMaterial


' ========== 6. 依赖关系 (Dependency) ==========
' 虚线箭头
CulturalRelic ..> QRCodeUtil
ImageLibrary ..> FileStorageUtil
SysUser ..> JwtUtil
SysUser ..> UserContextUtil

' ========== 图例 ==========
legend bottom right
  | 关系类型 | 连线符号 | 含义 |
  | -------- | -------- | ---- |
  | 继承 | <\|-- | 实线 + 空心三角形 |
  | 实现 | <\|.. | 虚线 + 空心三角形 |
  | 聚合 | o-- | 实线 + 空心菱形 |
  | 组合 | *-- | 实线 + 实心菱形 |
  | 关联 | --> | 实线箭头 |
  | 依赖 | ..> | 虚线箭头 |
endlegend

@enduml